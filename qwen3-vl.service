# Qwen3-VL Web Service - systemd 서비스 파일
#
# 사용법:
#   sudo cp qwen3-vl.service /etc/systemd/system/
#   sudo systemctl daemon-reload
#   sudo systemctl enable --now qwen3-vl
#   sudo systemctl status qwen3-vl
#
# 로그 확인:
#   journalctl -u qwen3-vl -f
#
# uvicorn 경로 확인 (conda 환경 사용 시):
#   which uvicorn   →  예) /home/handuru/miniconda3/envs/ocr/bin/uvicorn
#   ExecStart 의 uvicorn 을 위 전체 경로로 교체할 것

[Unit]
Description=Qwen3-VL Web Service by 김상민 (FastAPI + uvicorn, port 8001)
After=network-online.target
Wants=network-online.target
# Ollama 서비스가 먼저 기동되어 있어야 한다
Wants=ollama.service
After=ollama.service

[Service]
Type=simple
User=handuru
WorkingDirectory=/var/www/atpia.com/public_html/qwen3-vl

# ── 환경변수 파일 ──────────────────────────────────────────────────────────────
EnvironmentFile=/var/www/atpia.com/public_html/qwen3-vl/.env

# ── 기동 명령 ─────────────────────────────────────────────────────────────────
ExecStart=/home/handuru/miniconda3/bin/uvicorn main:app --host 127.0.0.1 --port 8001

# ── 재시작 정책 ───────────────────────────────────────────────────────────────
Restart=always
RestartSec=5
# 이미지 처리로 인한 긴 응답 시간을 고려해 타임아웃을 넉넉히 설정
TimeoutStartSec=60
TimeoutStopSec=10

# ── 로그 ──────────────────────────────────────────────────────────────────────
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
